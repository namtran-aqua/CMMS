@page "/maintenance"
@using AntDesign
@using CMMS.Client.Modals.Maintenances
@using CMMS.Shared.Dtos.Maintenance
@* @using Microsoft.AspNetCore.Components.Authorization *@
@inject HttpClient httpClient
@inject IMessageService Message
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@* @inject AuthenticationStateProvider AuthStateProvider *@
<PageTitle>Maintenance</PageTitle>

<style>
    .tab-item {
        padding: 8px 16px;
        background: #f5f5f5;
        border-radius: 10px;
        cursor: pointer;
    }

        .tab-item.active {
            background: white;
            border: 1px solid #ddd;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }


    .badge {
        background: #ddd;
        border-radius: 12px;
        padding: 2px 8px;
        margin-left: 6px;
        main.content {
        height: auto !important;
    }

}
</style>

<div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Maintenance</h3>
            <p class="text-muted">Manage equipment maintenance records</p>
        </div>
    </div>

    <!-- TAB -->
    <div style="display:flex; gap:10px; margin-bottom:20px;">

        <div class="tab-item @(selectedTab == "Pending" ? "active" : "")"
             @onclick='() => selectedTab = "Pending"'>
            ⏱ Pending
        </div>

        <div class="tab-item @(selectedTab == "History" ? "active" : "")"
             @onclick='() => selectedTab = "History"'>
            📄 History
        </div>


    </div>
    @if (selectedTab == "Pending")
    {
        <!-- Pending Search/Sort -->
        <div class="card p-3 mb-4 search-card" style="border-radius:15px">
            <div class="search-container" style="display:flex; gap:10px">
                <input class="form-control search-input" style="border-radius:10px; flex:1"
                       placeholder="Search by equipment name, location, or PIC..."
                       @bind-value="pendingSearchText" @bind-value:event="oninput" />

                <select class="form-select sort-select" style="width:200px; border-radius:10px" @bind="pendingSortBy">
                    <option value="DueDateAsc">Due Date (Earliest)</option>
                    <option value="DueDateDesc">Due Date (Latest)</option>
                    <option value="NameAsc">Name (A-Z)</option>
                    <option value="NameDesc">Name (Z-A)</option>
                </select>
            </div>
        </div>

        <!-- Pending Lists -->
        <div class="row">
            @foreach (var item in FilteredOverDue)
            {
                var maintenance = GetMaintenanceText(item.NextMaintenanceDate);

                <div class="col-4 mb-3">
                    <div class="card p-3"
                         style="border-radius:12px;
                               border:1px solid @(maintenance.color == "red" ? "#ff4d4f" :
                                                                   maintenance.color == "orange" ? "#faad14" : "#d9d9d9");
                               background-color:@(maintenance.color == "red" ? "#fff1f0" :
                                                                   maintenance.color == "orange" ? "#fffbe6" : "#ffffff");">

                        <!-- Header -->
                        <div class="d-flex justify-content-between">
                            <h5>@item.EquipmentName</h5>

                            <span style="color:@maintenance.color; font-size:12px">
                                @maintenance.text
                            </span>
                        </div>

                        <div class="text-muted">@item.LocName</div>
                        <div class="text-muted">@item.PIC</div>

                        <div class="mt-3">
                            <div>Scheduled: @item.NextMaintenanceDate?.ToString("MMM dd, yyyy")</div>
                            <div>Circle: @item.MaintenanceCircleTime days</div>
                        </div>

                        <!-- Button -->
                        <button class="btn btn-dark mt-3"
                                @onclick="() => CreatedAsync(item.EQID)">
                            🔧 Record Maintenance
                        </button>
                    </div>
                </div>
            }

            @foreach (var item in FilteredDueSoon)
            {
                var maintenance = GetMaintenanceText(item.NextMaintenanceDate);

                <div class="col-4 mb-3">
                    <div class="card p-3"
                         style="border-radius:12px;
                               border:1px solid @(maintenance.color == "red" ? "#ff4d4f" :
                                                                   maintenance.color == "orange" ? "#faad14" : "#d9d9d9");
                               background-color:@(maintenance.color == "red" ? "#fff1f0" :
                                                                   maintenance.color == "orange" ? "#fffbe6" : "#ffffff");">

                        <!-- Header -->
                        <div class="d-flex justify-content-between">
                            <h5>@item.EquipmentName</h5>

                            <span style="color:@maintenance.color; font-size:12px">
                                @maintenance.text
                            </span>
                        </div>

                        <div class="text-muted">@item.LocName</div>
                        <div class="text-muted">@item.PIC</div>

                        <div class="mt-3">
                            <div>Scheduled: @item.NextMaintenanceDate?.ToString("MMM dd, yyyy")</div>
                            <div>Circle: @item.MaintenanceCircleTime days</div>
                        </div>

                        <!-- Button -->
                        <button class="btn btn-dark mt-3" 
                                @onclick="() => CreatedAsync(item.EQID)">
                            🔧 Record Maintenance
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    else if (selectedTab == "History")
    {
        <!-- History Search/Sort -->
        <div class="card p-3 mb-4 search-card" style="border-radius:15px">
            <div class="search-container" style="display:flex; gap:10px">

                <!-- Search Input -->
                <input class="form-control search-input" style="border-radius:10px; flex:1"
                       placeholder="Search by equipment name, technician, or description..."
                       @bind-value="historySearchText" @bind-value:event="oninput" />

                <!-- Status Filter -->
                <select class="form-select status-filter" style="width:200px; border-radius:10px" @bind="historyStatusFilter">
                    <option value="0">All Type</option>
                    <option value="1">Routine</option>
                    <option value="2">Repair</option>
                </select>

                <!-- Sort Dropdown -->
                <select class="form-select sort-select" style="width:200px; border-radius:10px" @bind="historySortBy">
                    <option value="DateDesc">Date (Latest)</option>
                    <option value="DateAsc">Date (Earliest)</option>
                    <option value="CostDesc">Cost (Highest)</option>
                    <option value="CostAsc">Cost (Lowest)</option>
                    <option value="NameAsc">Equipment (A-Z)</option>
                    <option value="NameDesc">Equipment (Z-A)</option>
                </select>

            </div>
        </div>
        <div class="card p-3 mb-4" style="border-radius:15px">
            <div>
                <div><h6>Maintenance Records</h6></div>
                <div>@FilteredHistory.Count records total</div>
            </div>
            <!-- Equipment Table -->
            <table class="table">
                <thead>
                    <tr>
                        <th>Equipment</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Technician</th>
                        <th>Date</th>
                        <th>Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredHistory != null && FilteredHistory.Any())
                    {
                        foreach (var item in FilteredHistory)
                        {
                            <tr>
                                <td>
                                    <div>@GetEquipmentName(item.EQID)</div>
                                </td>
                                <td>
                                    <span class="@(item.StsMainID == 2 ? "badge bg-primary text-white" : "badge bg-info text-white")">
                                        @GetStsMainName(item.StsMainID)
                                    </span>
                                </td>
                                <td>@item.MaintDescription</td>
                                <td>@item.MaintPIC</td>
                                <td>@item.MaintDate?.ToString("dd/MM/yyyy")</td>
                                <td>@String.Format("{0:N0} VND", item.MaintPrice)</td>
                            </tr>
                        }
                    }
                </tbody>

            </table> 

        </div>
    }
</div>
<MaintenanceModel OnSave="LoadData" @ref="_maintenanceModal"/>