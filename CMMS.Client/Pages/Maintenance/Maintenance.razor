@page "/maintenance"
@using AntDesign
@using CMMS.Client.Modals.Maintenances
@using CMMS.Shared.Dtos.Maintenance
@using CMMS.Shared.Authorization
@* @using Microsoft.AspNetCore.Components.Authorization *@
@inject HttpClient httpClient
@inject IMessageService Message
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@* @inject AuthenticationStateProvider AuthStateProvider *@
<PageTitle>Maintenance</PageTitle>

<style>
    .tab-container {
        display: flex;
        gap: 8px;
        margin-bottom: 24px;
        background: #e2e8f0;
        padding: 5px;
        border-radius: 12px;
        width: fit-content;
    }

    .tab-item {
        padding: 8px 20px;
        background: transparent;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        color: #64748b;
        transition: all 0.2s ease;
    }

    .tab-item:hover {
        color: #0f172a;
    }

    .tab-item.active {
        background: #ffffff;
        color: #0f172a;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .badge {
        background: #ddd;
        border-radius: 12px;
        padding: 2px 8px;
        margin-left: 6px;
    }
    
    .maintenance-card {
        border-radius: 16px !important;
        border: 1px solid rgba(226, 232, 240, 0.8) !important;
        background: #ffffff;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.03) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .maintenance-card:hover {
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.07) !important;
        transform: translateY(-2px);
    }
</style>

<div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Maintenance</h3>
            <p class="text-muted">Manage equipment maintenance records</p>
        </div>
    </div>

    <!-- TAB -->
    <div class="tab-container">
        <div class="tab-item @(selectedTab == "Pending" ? "active" : "")"
             @onclick='() => selectedTab = "Pending"'>
            ⏱ Pending @(FilteredOverDue.Count + FilteredDueSoon.Count)
        </div>

        <div class="tab-item @(selectedTab == "History" ? "active" : "")"
             @onclick='() => selectedTab = "History"'>
            📄 History
        </div>
    </div>
    @if (selectedTab == "Pending")
    {
        <!-- Pending Search/Sort -->
        <div class="card p-3 mb-4 search-card" style="border-radius:15px">
            <div class="search-container" style="display:flex; gap:10px">
                <input class="form-control search-input" style="border-radius:10px; flex:1"
                       placeholder="Search by equipment name, location, or PIC..."
                       @bind-value="pendingSearchText" @bind-value:event="oninput" />

                <select class="form-select sort-select" style="width:200px; border-radius:10px" @bind="pendingSortBy">
                    <option value="DueDateAsc">Due Date (Earliest)</option>
                    <option value="DueDateDesc">Due Date (Latest)</option>
                    <option value="NameAsc">Name (A-Z)</option>
                    <option value="NameDesc">Name (Z-A)</option>
                </select>
            </div>
        </div>

        <!-- Pending Lists -->
        <div class="row">
            @foreach (var item in FilteredOverDue)
            {
                var maintenance = GetMaintenanceText(item.NextMaintenanceDate);

                <div class="col-4 mb-3">
                    <div class="maintenance-card p-4"
                         style="border-color: @(maintenance.color == "red" ? "#ffa39e" : "#f0f0f0") !important;
                                background-color: @(maintenance.color == "red" ? "#fff1f0" : "#ffffff") !important;">

                        <!-- Header -->
                        <div class="d-flex justify-content-between mb-2">
                            <h5 style="font-weight: 700; color: #1e293b; margin-bottom: 0;">@item.EquipmentName</h5>

                            @* <span class="badge" style="background-color: @(maintenance.color == "red" ? "#ff4d4f" : "#bfbfbf"); color: white; font-size: 11px; font-weight: 600;">
                                @maintenance.text
                            </span> *@
                            <span style="
                                            background-color:@(maintenance.color == "red" ? "#ff4d4f" : "#bfbfbf");
                                            color:white;
                                            padding:4px 10px;
                                            border-radius:12px;
                                            font-size:12px;
                                            font-weight:600;">
                                @maintenance.text
                            </span>
                        </div>

                        <div class="text-muted mb-1" style="font-size: 13px;"><i class="fa-solid fa-location-dot me-1"></i> @item.LocName</div>
                        <div class="text-muted mb-2" style="font-size: 13px;"><i class="fa-solid fa-user me-1"></i> @item.PIC</div>

                        <div class="mt-3 p-2" style="background: rgba(255,255,255,0.6); border-radius: 8px; font-size: 13px;">
                            <div><strong>Scheduled:</strong> @item.NextMaintenanceDate?.ToString("MMM dd, yyyy")</div>
                            <div class="mt-1"><strong>Circle:</strong> @item.MaintenanceCircleTime days</div>
                        </div>

                        <!-- Button -->
                        @if (IsAuthenticated)
                        {
                            @if (AuthorizationHelper.CanEditOrMaintain(CurrentUser, item.FACID, item.PICID))
                            {
                                <button class="btn btn-dark mt-3 w-100"
                                @onclick="() => CreatedAsync(item.EQID)">
                                    🔧 Record Maintenance
                                </button>
                            }
                        }
                    </div>
                </div>
            }

            @foreach (var item in FilteredDueSoon)
            {
                var maintenance = GetMaintenanceText(item.NextMaintenanceDate);

                <div class="col-4 mb-3">
                    <div class="maintenance-card p-4"
                         style="border-color: @(maintenance.color == "orange" ? "#ffe58f" : "#f0f0f0") !important;
                                background-color: @(maintenance.color == "orange" ? "#fffbe6" : "#ffffff") !important;">

                        <!-- Header -->
                        <div class="d-flex justify-content-between mb-2">
                            <h5 style="font-weight: 700; color: #1e293b; margin-bottom: 0;">@item.EquipmentName</h5>

                            <span style="
                                    background-color:@(maintenance.color == "orange" ? "#fa8c16" : "#bfbfbf");
                                    color:white;
                                    padding:4px 10px;
                                    border-radius:12px;
                                    font-size:12px;
                                    font-weight:600;">
                                @maintenance.text
                            </span>
                        </div>

                        <div class="text-muted mb-1" style="font-size: 13px;"><i class="fa-solid fa-location-dot me-1"></i> @item.LocName</div>
                        <div class="text-muted mb-2" style="font-size: 13px;"><i class="fa-solid fa-user me-1"></i> @item.PIC</div>

                        <div class="mt-3 p-2" style="background: rgba(255,255,255,0.6); border-radius: 8px; font-size: 13px;">
                            <div><strong>Scheduled:</strong> @item.NextMaintenanceDate?.ToString("MMM dd, yyyy")</div>
                            <div class="mt-1"><strong>Circle:</strong> @item.MaintenanceCircleTime days</div>
                        </div>

                        <!-- Button -->
                        @if (IsAuthenticated)
                        {
                            @if (AuthorizationHelper.CanEditOrMaintain(CurrentUser, item.FACID, item.PICID))
                            {
                                <button class="btn btn-dark mt-3 w-100"
                                        @onclick="() => CreatedAsync(item.EQID)">
                                    🔧 Record Maintenance
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

    else if (selectedTab == "History")
    {
        <!-- History Search/Sort -->
        <div class="card p-3 mb-4 search-card" style="border-radius:15px">
            <div class="search-container" style="display:flex; gap:10px">

                <!-- Search Input -->
                <input class="form-control search-input" style="border-radius:10px; flex:1"
                       placeholder="Search by equipment name, technician, or description..."
                       @bind-value="historySearchText" @bind-value:event="oninput" />

                <!-- Status Filter -->
                <select class="form-select status-filter" style="width:200px; border-radius:10px" @bind="historyStatusFilter">
                    <option value="0">All Type</option>
                    <option value="1">Routine</option>
                    <option value="2">Repair</option>
                </select>

                <!-- Sort Dropdown -->
                <select class="form-select sort-select" style="width:200px; border-radius:10px" @bind="historySortBy">
                    <option value="DateDesc">Date (Latest)</option>
                    <option value="DateAsc">Date (Earliest)</option>
                    <option value="CostDesc">Cost (Highest)</option>
                    <option value="CostAsc">Cost (Lowest)</option>
                    <option value="NameAsc">Equipment (A-Z)</option>
                    <option value="NameDesc">Equipment (Z-A)</option>
                </select>

            </div>
        </div>
        <div class="card p-3 mb-4" style="border-radius:15px">
            <div>
                <div><h6>Maintenance Records</h6></div>
                <div>@FilteredHistory.Count records total</div>
            </div>
            <!-- Equipment Table -->
            <table class="table">
                <thead>
                    <tr>
                        <th>Equipment</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Technician</th>
                        <th>Date</th>
                        <th>Cost</th>
                        <th>Attachment</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredHistory != null && FilteredHistory.Any())
                    {
                        foreach (var item in FilteredHistory)
                        {
                            <tr>
                                <td>
                                    <div>@GetEquipmentName(item.EQID)</div>
                                </td>
                                <td>
                                    <span class="@(item.StsMainID == 2 ? "badge bg-primary text-white" : "badge bg-info text-white")">
                                        @GetStsMainName(item.StsMainID)
                                    </span>
                                </td>
                                <td>@item.MaintDescription</td>
                                <td>@item.MaintPIC</td>
                                <td>@item.MaintDate?.ToString("dd/MM/yyyy")</td>
                                <td>@String.Format("{0:N0} VND", item.MaintPrice)</td>
                                <td>
                                    @if (item.Attachments != null && item.Attachments.Any())
                                    {
                                        <div style="margin-top:6px;">
                                            @foreach (var att in item.Attachments)
                                            {
                                                <div style="display:flex;align-items:center;gap:6px;font-size:12px;">
                                                    <Icon Type="file" Theme="IconThemeType.Outline"
                                                          Style="color:#1677ff;font-size:12px;" />
                                                    <a href="@att.FilePath" target="_blank">@att.FileName</a>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    <Button Type="@ButtonType.Primary" Ghost Size="ButtonSize.Small" OnClick="() => ShowDetail(item)">
                                        <Icon Type="eye" Theme="IconThemeType.Outline" /> Detail
                                    </Button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table> 

        </div>
    }
</div>
<MaintenanceModel OnSave="LoadData" @ref="_maintenanceModal"/>
<MaintenanceDetailModel @ref="_detailModal" />