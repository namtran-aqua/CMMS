@page "/Maintenance"
@using AntDesign
<PageTitle>Maintenance</PageTitle>

<style>
    .tab-item {
        padding: 8px 16px;
        background: #f5f5f5;
        border-radius: 10px;
        cursor: pointer;
    }

        .tab-item.active {
            background: white;
            border: 1px solid #ddd;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }


    .badge {
        background: #ddd;
        border-radius: 12px;
        padding: 2px 8px;
        margin-left: 6px;
        main.content {
        height: auto !important;
    }

}
</style>

<div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Maintenance</h3>
            <p class="text-muted">Manage equipment maintenance records</p>
        </div>

        <button class="btn btn-dark">
            + Add Record
        </button>
    </div>

    <!-- TAB -->
    <div style="display:flex; gap:10px; margin-bottom:20px;">

        <div class="tab-item @(selectedTab == "Pending" ? "active" : "")"
             @onclick='() => selectedTab = "Pending"'>
            ⏱ Pending
            <span class="badge">@GetPendingCount()</span>
        </div>

        <div class="tab-item @(selectedTab == "History" ? "active" : "")"
             @onclick='() => selectedTab = "History"'>
            📄 History
        </div>

    </div>


    <!-- CARD -->
    <div class="row">
        @foreach (var item in GetFilteredData())
        {
            var maintenance = GetMaintenanceText(item.BuyDate);

            <div class="col-4 mb-3">
                <div class="card p-3"
                     style="border-radius:12px;
                                    border:1px solid @(maintenance.color == "red" ? "#ff4d4f" :
                                       maintenance.color == "orange" ? "#faad14" : "#ddd")">

                    <!-- Header -->
                    <div class="d-flex justify-content-between">
                        <h5>@item.EquipmentName</h5>

                        <span style="color:@maintenance.color; font-size:12px">
                            @maintenance.text
                        </span>
                    </div>

                    <!-- Location -->
                    <div class="text-muted">@item.Location</div>

                    <!-- Info -->
                    <div class="mt-3">
                        <div>Scheduled: @item.BuyDate?.ToString("MMM dd, yyyy")</div>
                        <div>Circle: @item.MaintenanceCircleTime days</div>
                    </div>

                    <!-- Button -->
                    <button class="btn btn-dark mt-3">
                        🔧 Record Maintenance
                    </button>
                </div>
            </div>
        }
    </div>

</div>
