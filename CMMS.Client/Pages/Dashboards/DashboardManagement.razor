@page "/dash-board"
@using AntDesign
@using CMMS.Client.Components.DashBoards.DashBoardCharts
@using CMMS.Client.Components.DashBoards.DashBoardFooters
@using CMMS.Client.Components.DashBoards.DashBoardHeaders
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
<PageTitle>DashBoard</PageTitle>
<h3>DashBoard</h3>
<p class="text-muted"> Equipment status overview</p>
@if (isLoading)
{
    <div style="text-align: center; margin-top: 50px;">
        <Spin Spinning="true" Tip="Đang tải dữ liệu..." />
    </div>
}
else
{
    <div class="dashboard-section">
        <DashBoardHeader DashBoardData="@FilteredDashBoardData" />
    </div>

    <div class="dashboard-section">
        <DashBoardChart DashBoardData="@FilteredDashBoardData" />
    </div>
    <div class="dashboard-section">
        <DashBoardFooter DashBoardData="@FilteredDashBoardData" />
    </div>
}
