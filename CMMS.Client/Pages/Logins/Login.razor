@page "/login"

@layout LoginLayout
@using AntDesign
@using CMMS.Shared.Dtos.AuthModels
@using System.IdentityModel.Tokens.Jwt
@inject IMessageService Message
<style>
    .login-page {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: radial-gradient(circle at 20% 30%, #dce4f7, #f5f8ff);
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-box {
        background-color: white;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
        width: 400px;
        text-align: center;
    }

        .login-box .login-logo img {
            width: 120px;
            margin-bottom: 20px;
        }

        .login-box h4 {
            margin-bottom: 20px;
            font-weight: 600;
            color: #005eb8;
        }

        .login-box .form-control {
            margin-bottom: 15px;
            height: 45px;
            font-size: 16px;
        }

    .btn-primary {
        background-color: #1677ff;
        border: none;
        width: 100%;
        padding: 12px;
        font-size: 16px;
        border-radius: 6px;
        transition: background-color 0.3s;
    }

        .btn-primary:hover {
            background-color: #0d5ed7;
        }

    .text-center a {
        color: #1677ff;
        text-decoration: none;
    }

</style>
<div class="login-page">
    <div class="login-box">
        <div class="login-logo">
            <img src="https://hrmsaquavietnam.com:6969/images/Aqua-Smart%20Home%20-%20blue.png" alt="AQUA smart home" />
        </div>

        @if (currentScreenState == LoginScreenState.Login)
        {
            <h4>Account Login</h4>

            <input class="form-control" placeholder="WorkDay"
                   @bind="username" @onkeyup="HandleKeyUp" disabled="@loading" />

            <div style="position: relative;">
                <input class="form-control" placeholder="Password"
                       type="@(showPassword ? "text" : "password")"
                       @bind="password" @onkeyup="HandleKeyUp" disabled="@loading" />
                <span @onclick="TogglePassword"
                      style="position:absolute; right:10px; top:50%; transform:translateY(-50%); cursor:pointer;font-size:20px">
                    @(showPassword ? "🙉" : "🙈")
                </span>
            </div>

            <button class="btn btn-primary" @onclick="DoLogin" disabled="@loading">
                Login
            </button>

            <div style="text-align: right; margin-top: 15px;">
                <a href="javascript:void(0)" @onclick="GoToForgotPassword" style="color: #1677ff; font-size: 14px;">Forgot Password?</a>
            </div>
        }
        else if (currentScreenState == LoginScreenState.ForgotPassword)
        {
            <h4>Forgot Password</h4>
            <div style="text-align: left; margin-bottom: 15px; font-size: 14px; color: #555;">
                Enter your WorkDay ID and registered Email to receive a 6-digit OTP code.
            </div>

            <input class="form-control" placeholder="WorkDay ID"
                   @bind="forgotWorkDayId" @onkeyup="HandleKeyUp" disabled="@loading" />

            <input class="form-control" placeholder="Email"
                   @bind="forgotEmail" @onkeyup="HandleKeyUp" disabled="@loading" />

            <button class="btn btn-primary" @onclick="SendOtp" disabled="@loading" style="margin-top: 10px;">
                Send OTP
            </button>

            <div style="margin-top: 15px; text-align: center;">
                <a href="javascript:void(0)" @onclick="GoToLogin" style="color: #1677ff; font-size: 14px;">Back to Login</a>
            </div>
        }
        else if (currentScreenState == LoginScreenState.VerifyOtp)
        {
            <h4>Verify OTP</h4>
            <div style="text-align: left; margin-bottom: 15px; font-size: 14px; color: #555;">
                A verification code has been sent to your email. Please enter it below.
            </div>

            <input class="form-control" placeholder="6-digit OTP"
                   @bind="otpCode" @onkeyup="HandleKeyUp" disabled="@loading" maxlength="6" />

            <button class="btn btn-primary" @onclick="VerifyOtp" disabled="@loading" style="margin-top: 10px;">
                Verify
            </button>

            <div style="margin-top: 15px; text-align: center;">
                <a href="javascript:void(0)" @onclick="GoToForgotPassword" style="color: #1677ff; font-size: 14px;">Back</a>
            </div>
        }
        else if (currentScreenState == LoginScreenState.ResetPassword)
        {
            <h4>Reset Password</h4>
            <div style="text-align: left; margin-bottom: 15px; font-size: 14px; color: #555;">
                Enter your new password below.
            </div>

            <div style="position: relative;">
                <input class="form-control" placeholder="New Password"
                       type="@(showNewPassword ? "text" : "password")"
                       @bind="newPassword" @onkeyup="HandleKeyUp" disabled="@loading" />
                <span @onclick="ToggleNewPassword"
                      style="position:absolute; right:10px; top:50%; transform:translateY(-50%); cursor:pointer;font-size:20px">
                    @(showNewPassword ? "🙉" : "🙈")
                </span>
            </div>

            <div style="position: relative;">
                <input class="form-control" placeholder="Confirm Password"
                       type="@(showConfirmPassword ? "text" : "password")"
                       @bind="confirmPassword" @onkeyup="HandleKeyUp" disabled="@loading" />
                <span @onclick="ToggleConfirmPassword"
                      style="position:absolute; right:10px; top:50%; transform:translateY(-50%); cursor:pointer;font-size:20px">
                    @(showConfirmPassword ? "🙉" : "🙈")
                </span>
            </div>

            <button class="btn btn-primary" @onclick="ResetPassword" disabled="@loading" style="margin-top: 10px;">
                Save
            </button>
        }
    </div>
</div>
