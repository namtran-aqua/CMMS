@namespace CMMS.Client.Pages.SpareParts.Tabs
@using AntDesign
@using CMMS.Shared.Dtos.SpareParts
@using CMMS.Client.Common
@using System.IO

<!-- Header -->
<div class="d-flex justify-content-between align-items-center">
    <div>
        <h3>Import Orders (Nhập kho)</h3>
        <p class="text-muted">Register new stocks, batch codes, and document attachments</p>
    </div>
    @if (IsAuthenticated)
    {
        <div>
            <Button Type="@ButtonType.Primary" OnClick="OpenCreateImportModal" Class="btn-custom">
                <Icon Type="plus" /> Create Import Order
            </Button>
        </div>
    }
</div>

<!-- Filters -->
<div class="card p-3 mb-3 search-card" style="border-radius:15px">
    <div style="display:flex; justify-content:space-between; align-items:center; cursor:pointer;" @onclick="() => isCatalogSearchPanelCollapsed = !isCatalogSearchPanelCollapsed">
        <div style="font-weight:700; color:#1e293b; font-size:14px;">
            <Icon Type="search" Style="margin-right:8px;" /> Advanced Search Filters
        </div>
        <div>
            <Icon Type="@(isCatalogSearchPanelCollapsed ? "down" : "up")" />
        </div>
    </div>

    @if (!isCatalogSearchPanelCollapsed)
    {
        <div class="row" style="gap:12px 0;">
            <div class="col-md-3">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Import Code</label>
                <Input placeholder="IMP-..." @bind-Value="importCodeSearch" Class="form-control" />
            </div>
            <div class="col-md-3">
                <label style="font-size:12px; font-weight:600; color:#64748b;">PO Number</label>
                <Input placeholder="PO number..." @bind-Value="importPoSearch" Class="form-control" />
            </div>
            @* <div class="col-md-3">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Vendor</label>
                <Select TValue="int?" @bind-Value="importVendorFilter" DataSource="Vendors" ValueName="VendorID" LabelName="VendorName" Placeholder="All Vendors" AllowClear Style="width:100%" />
            </div> *@
            <div class="col-md-3">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Category</label>
                <select class="form-select" @bind="importVendorFilter" style="height:38px; border-radius:8px;">
                    <option value="0">All Vendors</option>
                    @foreach (var c in Vendors)
                    {
                        <option value="@c.VendorID">@c.VendorName</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end" style="gap:8px;">
                <Button Type="@ButtonType.Primary" OnClick="ApplyFilters" Class="btn-custom">Query</Button>
                <Button Type="@ButtonType.Default" OnClick="ResetFilters" Class="btn-custom">Reset</Button>
            </div>
        </div>
    }
</div>

<!-- List card -->
<div class="card p-4 mb-4" style="border-radius:15px; overflow:hidden; padding: 24px !important;">
    <div class="d-flex justify-content-between align-items-center mb-3"> 
        <h6 class="mb-0" style="font-weight: 700; color: #1e293b;">Imports Register</h6>
        <p class="text-muted" style="font-size: 13px; font-weight: 500;">@FilteredImportOrders.Count orders found</p>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Import Code</th>
                <th>PO Number</th>
                <th>Vendor</th>
                <th>Import Date</th>
                <th>Created By</th>
                <th>File Đính Kèm</th>
                <th>Status</th>
                <th style="width: 120px;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (FilteredImportOrders != null && FilteredImportOrders.Any())
            {
                foreach (var imp in FilteredImportOrders.Skip((importPage - 1) * importPageSize).Take(importPageSize))
                {
                    <tr>
                        <td><strong>@imp.ImportCode</strong></td>
                        <td>@imp.PONumber</td>
                        <td>@imp.VendorName</td>
                        <td>@imp.ImportDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@imp.CreateUser</td>
                        <td>
                            @if (imp.AttachmentUrls != null && imp.AttachmentUrls.Any())
                            {
                                <div>
                                    @foreach (var url in imp.AttachmentUrls)
                                    {
                                        var fileName = System.IO.Path.GetFileName(url);
                                        var resolvedUrl = url.StartsWith("/") || url.StartsWith("http") ? url : "/" + url;
                                        <div style="display:flex;align-items:center;gap:6px;font-size:12px;margin-bottom:2px;">
                                            <Icon Type="file" Theme="IconThemeType.Outline" Style="color:#1677ff;font-size:12px;" />
                                            <a href="@resolvedUrl" target="_blank" title="@fileName">@fileName</a>
                                        </div>
                                    }
                                </div>
                            }
                        </td>
                        <td>
                            <span class="status-badge badge-@imp.Status.ToLower()">@imp.Status</span>
                        </td>
                        <td>
                            <Button Size="ButtonSize.Small" Class="btn-custom" OnClick="() => ShowImportDetail(imp.ImportID)"><Icon Type="eye" /> Details</Button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center; padding:30px; color:#94a3b8;">Không có lệnh nhập nào.</td>
                </tr>
            }
        </tbody>
    </table>
    @if (FilteredImportOrders != null && FilteredImportOrders.Any())
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span style="font-size:12px; color:#595959;">
                Showing @(((importPage - 1) * importPageSize) + 1) to @(Math.Min(importPage * importPageSize, FilteredImportOrders.Count)) of @FilteredImportOrders.Count orders
            </span>
            <Pagination Total="FilteredImportOrders.Count"
                        @bind-PageSize="importPageSize"
                        @bind-Current="importPage"
                        PageSizeOptions="new[] { 10, 20, 50, 100 }"
                        ShowSizeChanger="true"
                        OnChange="OnImportPageChange"
                        Size="PaginationSize.Small" />
        </div>
    }
</div>

<!-- 1. Import Order Details Modal -->
<Modal @bind-Visible="isImportDetailVisible" Title="Lệnh Nhập Kho Chi Tiết" Width="1000" Footer="null" Style="z-index:9999;">
    @if (selectedImportOrder != null)
    {
        <div style="display:flex; flex-direction:column; gap:12px;">
            <div class="row">
                <div class="col-6"><strong>Import Code:</strong> @selectedImportOrder.ImportCode</div>
                <div class="col-6"><strong>PO Number:</strong> @selectedImportOrder.PONumber</div>
                <div class="col-6"><strong>Supplier:</strong> @selectedImportOrder.VendorName</div>
                <div class="col-6"><strong>Date:</strong> @selectedImportOrder.ImportDate.ToString("yyyy-MM-dd HH:mm")</div>
                <div class="col-6"><strong>Created By:</strong> @selectedImportOrder.CreateUser</div>
                <div class="col-6">
                    <strong>Status:</strong>
                    <span class="status-badge badge-@selectedImportOrder.Status.ToLower()">@selectedImportOrder.Status</span>
                </div>
            </div>

            <h6 style="font-weight:700; margin-top:12px;">List import Spare Part</h6>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Serial Code</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in selectedImportOrder.Details)
                    {
                        <tr>
                            <td>@d.PartCode</td>
                            <td>@d.PartName</td>
                            <td>@(d.HasCode ? "Coded" : "No Code")</td>
                            <td>@d.SerialCode</td>
                            <td>@d.Quantity</td>
                            <td>@String.Format("{0:N0} VND", d.Price)</td>
                            <td><strong>@String.Format("{0:N0} VND", d.Quantity * d.Price)</strong></td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (selectedImportOrder.AttachmentUrls != null && selectedImportOrder.AttachmentUrls.Any())
            {
                <div style="margin-top:12px;">
                    <strong>Tệp đính kèm:</strong>
                    <div style="display:flex; flex-direction:column; gap:6px; margin-top:4px;">
                        @foreach (var url in selectedImportOrder.AttachmentUrls)
                        {
                            <a href="@url" target="_blank" style="font-size:12px; color:#3b82f6;"><Icon Type="paper-clip" /> @Path.GetFileName(url)</a>
                        }
                    </div>
                </div>
            }

            @if (selectedImportOrder.Status != "Reversed" && IsAuthenticated)
            {
                <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:20px; border-top:1px solid #f1f5f9; padding-top:12px;">
                    <Button Danger OnClick="() => ReverseImport(selectedImportOrder.ImportID)">
                        <Icon Type="rollback" /> Reverse
                    </Button>
                </div>
            }
        </div>
    }
</Modal>

<!-- 2. Create Import Order Modal -->
<Modal @bind-Visible="isImportCreateVisible" Title="Tạo đơn Nhập Kho" Width="1000" Footer="null" Style="z-index:9999;">
    <div style="display:flex; flex-direction:column; gap:16px;">
        <!-- Header Info -->
        <div class="row">
            <div class="col-md-4">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Số PO</label>
                <Input placeholder="Nhập số PO..." @bind-Value="newImportOrder.PONumber" />
            </div>
            <div class="col-md-4">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Nhà Cung Cấp</label>
                <Select TValue="int" @bind-Value="newImportOrder.VendorID" DataSource="Vendors" ValueName="VendorID" LabelName="VendorName" Placeholder="Chọn NCC" Style="width:100%;" />
            </div>
            <div class="col-md-4">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Ngày Nhập</label>
                <DatePicker TValue="DateTime" @bind-Value="newImportOrder.ImportDate" Style="width:100%; height:38px;" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <label style="font-size:12px; font-weight:600; color:#64748b; display:block;">Đính kèm tệp</label>
                <div style="display:flex; gap:12px; align-items:center;">
                    <Upload Action="@($"{Navigation.BaseUri}api/Common/upload-file-suport")"
                            Name="file"
                            Accept=".jpg,.jpeg,.png,.pdf,.docx,.xlsx"
                            ShowUploadList="false"
                            OnSingleCompleted="OnImportAttachmentUploaded">
                        <Button Icon="upload">Tải lên tài liệu</Button>
                    </Upload>
                    @if (newImportOrder.AttachmentUrls.Any())
                    {
                        <div style="font-size:12px; color:#10b981;">Đã tải lên @newImportOrder.AttachmentUrls.Count tệp</div>
                    }
                </div>
            </div>
        </div>

        <hr style="margin:8px 0;" />

        <!-- Detail Sub-Form -->
        <h6 style="font-weight:700; color:#0f172a; margin:0;">Thêm phụ tùng vào danh sách</h6>
        <div class="row align-items-end" style="gap:12px 0;">
            <div class="col-md-5">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Chọn Phụ Tùng</label>
                <Select TValue="int"
                        @bind-Value="selectedImportPartId"
                        DataSource="importPartsSearchList"
                        ValueName="SPID"
                        LabelName="DisplayName"
                        Placeholder="Nhập tên/mã phụ tùng..."
                        ShowSearch
                        EnableSearch
                        OnSearch="SearchPartsForImport"
                        Style="width:100%" />
            </div>

            @if (tempImportDetail.HasCode)
            {
                <div class="col-md-4">
                    <label style="font-size:12px; font-weight:600; color:#64748b;">Mã Serial/Code (Chỉ 1 con)</label>
                    <Input placeholder="Nhập mã serial duy nhất..." @bind-Value="tempImportDetail.SerialCode" />
                </div>
            }
            else
            {
                <div class="col-md-2">
                    <label style="font-size:12px; font-weight:600; color:#64748b;">Số Lượng</label>
                    <AntDesign.InputNumber TValue="int" @bind-Value="tempImportDetail.Quantity" Min="1" Style="width:100%" />
                </div>
            }

            <div class="col-md-3">
                <label style="font-size:12px; font-weight:600; color:#64748b;">Giá Nhập (VND)</label>
                <AntDesign.InputNumber TValue="decimal?" @bind-Value="tempImportDetail.Price" Min="0" Style="width:100%" />
            </div>

            <div class="col-md-2">
                <Button Type="@ButtonType.Default" OnClick="AddItemToNewImport" Style="width:100%; height:38px; border-radius:8px;">Thêm</Button>
            </div>
        </div>

        <!-- Detail Listing -->
        <table class="table table-striped" style="margin-top:12px;">
            <thead>
                <tr>
                    <th>Mã Phụ Tùng</th>
                    <th>Tên Phụ Tùng</th>
                    <th>Serial Code</th>
                    <th>Số Lượng</th>
                    <th>Giá Nhập</th>
                    <th>Thành Tiền</th>
                    <th style="width: 50px;">Xóa</th>
                </tr>
            </thead>
            <tbody>
                @if (newImportOrder.Details.Any())
                {
                    foreach (var det in newImportOrder.Details)
                    {
                        <tr>
                            <td>@det.PartCode</td>
                            <td>@det.PartName</td>
                            <td>@(det.HasCode ? det.SerialCode : "Không code")</td>
                            <td>@det.Quantity</td>
                            <td>@String.Format("{0:N0} VND", det.Price)</td>
                            <td><strong>@String.Format("{0:N0} VND", det.Quantity * det.Price)</strong></td>
                            <td>
                                <Button Danger Size="ButtonSize.Small" OnClick="() => RemoveImportDetail(det)"><Icon Type="delete" /></Button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center; color:#94a3b8;">Chưa có phụ tùng nào được thêm.</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Actions -->
        <div style="display:flex; justify-content:flex-end; gap:8px; border-top:1px solid #f1f5f9; padding-top:12px; margin-top:12px;">
            <Button OnClick="() => isImportCreateVisible = false" Style="border-radius:8px;">Hủy</Button>
            <Button Type="@ButtonType.Primary" OnClick="SaveNewImportOrder" Style="border-radius:8px;">Lưu Phiếu</Button>
        </div>
    </div>
</Modal>
