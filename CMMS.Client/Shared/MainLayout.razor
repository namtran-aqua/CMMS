@inherits LayoutComponentBase
@using CMMS.Client.Shared
@using CMMS.Client.Services
@using AntDesign
<div class="app-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <div style="font-size: 20px; font-weight: 600;" class="sidebar-header">
            <div class="logo-box">
                <i class="fa-solid fa-sliders"></i>
            </div>
            <div class="sidebar-title">
                <div class="title">Equipment Manager</div>
                <div class="subtitle">EMS v1.0</div>
            </div>
        </div>

        <Menu Mode="MenuMode.Inline"
              Theme="MenuTheme.Light"
              Class="custom-menu">

            <MenuItem>
                <NavLink href="@GetLink("/dash-board")" class="menu-link" Match="NavLinkMatch.All">
                    <i class="fa-solid fa-table-cells menu-icon"></i>
                    <span>Dashboard</span>
                </NavLink>
            </MenuItem>

            <MenuItem>
                <NavLink href="@GetLink("/equipment")" class="menu-link">
                    <i class="fa-solid fa-sliders menu-icon"></i>
                    <span>Equipment</span>
                </NavLink>
            </MenuItem>

            <MenuItem>
                <NavLink href="@GetLink("/maintenance")" class="menu-link">
                    <i class="fa-solid fa-wrench menu-icon"></i>
                    <span>Maintenance</span>
                </NavLink>
            </MenuItem>

            <MenuItem>
                <NavLink href="@GetLink("/spare-parts")" class="menu-link">
                    <i class="fa-solid fa-box menu-icon"></i>
                    <span>Spare Parts</span>
                </NavLink>
            </MenuItem> 

        </Menu>
    </aside>

    <!-- MAIN - LOGIN INFO-->
    <section class="main">
        <header class="topbar">
            <!-- Factory Selector -->
            <div class="factory-filter">

                <div class="factory-select-wrapper">

                    <i class="fa-solid fa-warehouse factory-icon"></i>

                    <select class="factory-select"
                            @onchange="OnFactoryChanged"
                            value="@(FactoryState.SelectedFacId?.ToString() ?? "")">

                        <option value="">All Factories</option>

                        @foreach (var fac in FactoryState.Factories)
                        {
                            <option value="@fac.FacId">
                                @fac.FacCode - @fac.FacName
                            </option>
                        }

                    </select>

                    <i class="fa-solid fa-chevron-down factory-arrow"></i>

                </div>

            </div>

            @if (CurrentUser != null && !string.IsNullOrEmpty(CurrentUser.FullName))
            {
                <div class="user-display">
                    @if (!string.IsNullOrEmpty(CurrentUser.Avatar))
                    {
                        <img class="user-avatar" src="@CurrentUser.Avatar" alt="Avatar" />
                    }
                    else
                    {
                        <div class="user-avatar-placeholder">
                            @CurrentUser.FullName.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <div class="user-details">
                        <div class="user-fullname">@CurrentUser.FullName</div>
                        <div class="user-workday">ID: @CurrentUser.WorkDayId</div>
                    </div>
                    <button class="btn btn-logout" @onclick="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-login" @onclick="GoToLogin">
                    <i class="fa-solid fa-right-to-bracket"></i> Login
                </button>
            }
        </header>
        <main class="content">
            @Body
        </main>
    </section>

</div>
