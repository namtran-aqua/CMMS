@using AntDesign
@using CMMS.Shared.Dtos.Equipment
@using CMMS.Shared.Dtos.User
@using CMMS.Shared.Dtos.Maintenance.Attachments
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient httpClient
@inject IMessageService Message
@inject CurrentUserInfo CurrentUserInfo
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider



<style>
    .ant-select-selector {
        font-size: 14px !important;
        font-weight: 400 !important;
        height: 38px !important;
        display: flex;
        align-items: center;
    }

    .ant-select-selection-item {
        font-size: 14px !important;
        font-weight: 400 !important;
    }

    .ant-select-arrow {
        font-size: 12px;
    }

    .ant-input {
        font-size: 14px;
        height: 38px;
    }

    .ant-select-selection-placeholder {
        color: #bfbfbf !important;
        font-size: 14px !important;
        font-weight: 400 !important;
    }

    .its-attach-area {
        margin-top: 20px;
        border-top: 1px solid #f0f0f0;
        padding-top: 15px;
    }

    .its-attach-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .its-section-title {
        font-weight: 600;
        font-size: 14px;
        color: #262626;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .style-attach {
        background-color: #fafafa;
        border-radius: 8px;
        border: 1px solid #f0f0f0;
    }
</style>
@{
    RenderFragment footer = @<Template>
        <Button OnClick="@SaveAsync" Type="ButtonType.Primary">
            Save
        </Button>

        <Button OnClick="@Close">Cancel</Button>
        
    </Template>;
}

<Modal @bind-Visible="IsModalVisible"
       Title="Add Maintenance Record"
       Style="z-index:9999;width:700px"
       Footer="@footer">

    <p style="color:gray;margin-bottom:16px">
        Record a maintenance activity
    </p>

    <Form @ref="@formRef"
          Model="@MaintenanceDto"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync">

        <!-- Equipment Name -->
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Maintenance Type" Name="StsMainID" Required>
                    <Select TValue="int"
                            @bind-Value="MaintenanceDto.StsMainID"
                            DataSource="MaintenanceStatuses"
                            ValueName="Id"
                            LabelName="Name"
                            Placeholder="Select type"
                            Style="width:100%">
                    </Select>
                </FormItem>
            </Col>
            
            <Col Span="12">
                <FormItem Label="Vendor" Name="VendorID">
                <Select TValue="int?"
                        @bind-Value="MaintenanceDto.VendorID"
                        DataSource="Vendors"
                        ValueName="VendorID"
                        LabelName="VendorName"
                        Placeholder="Select vendor"
                        AllowClear>
                    </Select>
                </FormItem>
            </Col>
        </Row>
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="PICID" Name="PICID">
                <Select TValue="string?"
                        @bind-Value="MaintenanceDto.PICID"
                        DataSource="Users"
                        ValueName="WorkDayId"
                        LabelName="FullName"
                        Placeholder="Select PIC"
                        ShowSearch
                        EnableSearch>
                </Select>

            </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="MaintPrice" Name="MaintPrice">
                <AntDesign.InputNumber TValue="decimal?"
                    @bind-Value="MaintenanceDto.MaintPrice"
                           Placeholder="Enter MaintPrice" 
                                       Style="width:100%" />
                </FormItem>
            </Col>
        </Row>
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="Description" Name="MaintDescription">
                <Input @bind-Value="MaintenanceDto.MaintDescription"
                       Placeholder="Enter Maint Description" />
                </FormItem>
            </Col>
            @* <Col Span="12">
            <FormItem Label="Maint Note" Name="MaintNote">
                <Input @bind-Value="MaintenanceDto.MaintNote" 
                       Placeholder="Enter Maint Note" />
                </FormItem>
            </Col> *@
            <Col Span="12">
            <FormItem Label="Maint Date" Name="MaintDate">
                <DatePicker @bind-Value="MaintenanceDto.MaintDate"
                            Style="width:100%" />
            </FormItem>
            </Col>
        </Row>
        @* <Row Gutter="16">
            
        </Row> *@
        <!-- Attachments -->
        <div class="its-attach-area">
            <div class="its-attach-header">
                <div class="its-section-title" style="margin-bottom:0;">
                    <Icon Type="paper-clip" Theme="IconThemeType.Outline" Style="font-size:12px;" />
                    Attachments
                </div>
                <Upload Action="@($"{Navigation.BaseUri}api/Common/upload-file-suport")"
                        Name="file"
                        Accept=".jpg,.jpeg,.png,.xlsx,.docx,.pdf,.slx"
                        BeforeUpload="BeforeUpload1"
                        ShowUploadList="false"
                        OnSingleCompleted="OnSingleCompleted">
                    <Button Shape="ButtonShape.Round"
                            Size="ButtonSize.Small"
                            Icon="upload"
                            Style="font-size:12px;">
                        Upload file
                    </Button>
                </Upload>
            </div>

            @if (Attachment != null && Attachment.Any())
            {
                <Table Class="style-attach"
                       DataSource="Attachment"
                       HidePagination
                       Size="TableSize.Small"
                       TItem="AttachmentDto">
                    <ChildContent Context="file">
                        <Column Title="File name" TData="string">
                            <div style="display:flex;align-items:center;gap:7px;">
                                <Icon Type="file" Theme="IconThemeType.Outline"
                                      Style="color:#1677ff;font-size:14px;" />
                                <span style="font-size:12px;">@file.FileName</span>
                            </div>
                        </Column>
                        <Column Title="Size" Width="90" TData="long">
                            <span style="font-size:11px;color:#595959;">@FormatSize(file.FileSize)</span>
                        </Column>
                        <Column Title="Uploaded" Width="170" TData="DateTime">
                            <span style="font-size:11px;color:#595959;">
                                @file.CreatedTime.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </Column>
                        <ActionColumn Width="50">
                            <Button Icon="delete"
                                    Type="ButtonType.Link"
                                    Danger="true"
                                    Size="ButtonSize.Small"
                                    OnClick="() => Deleted(file)" />
                        </ActionColumn>
                    </ChildContent>
                </Table>
            }
            else
            {
                <div style="text-align:center;padding:12px 0;font-size:12px;color:#8c8c8c;">
                    No attachments yet
                </div>
            }
        </div>
    </Form>
</Modal>