@namespace CMMS.Client.Modals.SpareParts
@using AntDesign
@using CMMS.Shared.Dtos.SpareParts
@inject IMessageService Message

<style>
    .ant-select-selector {
        font-size: 14px !important;
        font-weight: 400 !important;
        height: 38px !important;
        display: flex;
        align-items: center;
    }

    .ant-select-selection-item {
        font-size: 14px !important;
        font-weight: 400 !important;
    }

    .ant-select-arrow {
        font-size: 12px;
    }

    .ant-input {
        font-size: 14px;
        height: 38px;
    }

    .ant-select-selection-placeholder {
        color: #bfbfbf !important;
        font-size: 14px !important;
        font-weight: 400 !important;
    }
</style>

@{
    RenderFragment footer = @<Template>
        <Button OnClick="@SaveAsync" Type="ButtonType.Primary" Class="btn-custom">
            Save
        </Button>
        <Button OnClick="@Close" Class="btn-custom">
            Cancel
        </Button>
    </Template>;
}

<Modal @bind-Visible="IsModalVisible"
       Title="@(PartDto.SPID == 0 ? "Add Spare Part" : "Edit Spare Part")"
       Style="z-index:9999;width:600px"
       Footer="@footer">

    <Form @ref="@formRef" Model="@PartDto" Layout="FormLayout.Vertical" OnFinish="SaveAsync">
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Code" Name="Code" Required>
                    <Input @bind-Value="PartDto.PartCode"/>
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Name" Name="Name" Required>
                    <Input @bind-Value="PartDto.PartName" Placeholder="Part name" />
                </FormItem>
            </Col>
        </Row>

        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Category" Name="CategoryID">
                    <Select TValue="int?"
                            @bind-Value="PartDto.CategoryID"
                            DataSource="Categories"
                            ValueName="CategoryID"
                            LabelName="CategoryName"
                            AllowClear />
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Supplier" Name="SupplierID">
                    <Select TValue="int?"
                            @bind-Value="PartDto.SupplierID"
                            DataSource="Suppliers"
                            ValueName="SupplierID"
                            LabelName="SupplierName"
                            AllowClear />
                </FormItem>
            </Col>
        </Row>

        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Price" Name="Price">
                    <AntDesign.InputNumber TValue="decimal?" @bind-Value="PartDto.Price" Style="width:100%; height:38px" Min="0" />
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Unit" Name="Unit">
                    <Input @bind-Value="PartDto.Unit" />
                </FormItem>
            </Col>
        </Row>
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Location" Name="LocID">
                    <Select TValue="int?"
                            @bind-Value="PartDto.LocID"
                            DataSource="Locations"
                            ValueName="LocID"
                            LabelName="LocName"
                            Placeholder="Select location"
                            AllowClear />
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Department" Name="DeptID">
                    <Select TValue="int?"
                            @bind-Value="PartDto.DeptID"
                            DataSource="FilteredDepartments"
                            ValueName="DeptID"
                            LabelName="DeptFullName"
                            Placeholder="Select department"
                            ShowSearch
                            AllowClear>
                    </Select>
                </FormItem>
            </Col>
        </Row>

        <Row Gutter="16">
            @* @if (PartDto.SPID == 0)
            {
                <AntDesign.Col Span="8">
                    <FormItem Label="Initial Qty" Name="Inventory">
                        <AntDesign.InputNumber TValue="int?" @bind-Value="PartDto.Inventory" Style="width:100%" Min="0" Disabled="@PartDto.IsCoded" />
                    </FormItem>
                </AntDesign.Col>
            } *@
            <Col Span="12">
                <FormItem Label="Min Stock" Name="MinStock">
                    <AntDesign.InputNumber TValue="int?" @bind-Value="PartDto.MinStock" Style="width:100%; height: 38px;" Min="0" />
                </FormItem>
            </Col>

            <Col Span="4">
                <FormItem Label="IsCoded" Name="IsCoded">
                    <Switch @bind-Value="PartDto.IsCoded" CheckedChildren="Coded" UnCheckedChildren="None" />
                </FormItem>
            </Col>
            <Col Span="8">
                <FormItem Label="Spare Part Image">
                    <div style="display:flex; flex-direction:column; gap:8px;">
                        <Upload Action="@($"{Navigation.BaseUri}api/Common/upload-file-suport")"
                                Name="file"
                                Accept=".jpg,.jpeg,.png"
                                ShowUploadList="false"
                                OnSingleCompleted="OnImageUploadCompleted"
                                Style="width: 100%;">
                            <Button Icon="upload" Style="border-radius: 8px; height: 38px; width: 100%;">Upload Image</Button>
                        </Upload>
                        @if (!string.IsNullOrEmpty(PartDto.ImageUrl))
                        {
                            <div style="display:flex; align-items:center; gap:8px;">
                                <img src="@PartDto.ImageUrl" style="width:38px; height:38px; object-fit:cover; border-radius:4px; border:1px solid #d9d9d9;" />
                                <Button Type="ButtonType.Link" Danger OnClick="@(() => PartDto.ImageUrl = null)" Style="padding: 0;">Remove</Button>
                            </div>
                        }
                    </div>
                </FormItem>
            </Col>
        </Row>

        

        @* <Row Gutter="16">
            
            
        </Row> *@

        <FormItem Label="Note" Name="Note">
            <TextArea @bind-Value="PartDto.Note" Rows="2" />
        </FormItem>

        @if (PartDto.SPID != 0)
        {
            <div style="font-size:12px;color:#8c8c8c;">
                Current stock: <strong>@PartDto.Inventory @PartDto.Unit</strong> — use "Adjust stock" on the parts table to change quantity.
            </div>
        }
    </Form>
</Modal>