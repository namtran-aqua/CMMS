@using AntDesign
@using CMMS.Shared.Dtos.Equipment
@inject HttpClient httpClient
@inject IMessageService Message

<style>
    .ant-select-selector {
        font-size: 14px !important;
        font-weight: 400 !important;
        height: 38px !important;
        display: flex;
        align-items: center;
    }

    .ant-select-selection-item {
        font-size: 14px !important;
        font-weight: 400 !important;
    }

    .ant-select-arrow {
        font-size: 12px;
    }

    .ant-input {
        font-size: 14px;
        height: 38px;
    }

    .ant-select-selection-placeholder {
        color: #bfbfbf !important;
        font-size: 14px !important;
        font-weight: 400 !important;
    }
</style>
@{
    RenderFragment footer = @<Template>
        <Button OnClick="@SaveAsync" Type="ButtonType.Primary">
            Save
        </Button>

        <Button OnClick="@Close">Cancel</Button>
    </Template>;
}

<Modal @bind-Visible="IsModalVisible"
       Title="Equipment"
       Style="z-index:9999;width:700px"
       Footer="@footer">

    <p style="color:gray;margin-bottom:16px">
        Enter the equipment information
    </p>

    <Form @ref="@formRef"
          Model="@EquipmentDto"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync">

        <!-- Equipment Name -->
        <Row Gutter="16">
            <Col Span="24">
                <FormItem Label="Equipment Name" Name="EquipmentName" Required>
                    <Input @bind-Value="EquipmentDto.EquipmentName"
                           Placeholder="e.g., CNC Lathe CNC-1" />
                </FormItem>
            </Col>
        </Row>
        <!-- Code + Barcode -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="Equipment Code" Name="EquipmentCode">
                <Input @bind-Value="EquipmentDto.EquipmentCode"
                       Placeholder="e.g., FANUC α-D21MiB5" />
            </FormItem>
            </Col>

            <Col Span="12">
            <FormItem Label="Equipment Barcode" Name="EquipmentBarcode">
                <Input @bind-Value="EquipmentDto.EquipmentBarcode"
                       Placeholder="e.g., FNC-2023-001" />
            </FormItem>
            </Col>
        </Row>
        <!-- Model + Serial -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="Equipment Model" Name="EquipmentModel">
                    <Input @bind-Value="EquipmentDto.EquipmentModel"
                           Placeholder="e.g., FANUC α-D21MiB5" />
                </FormItem>
            </Col>

            <Col Span="12">
            <FormItem Label="Equipment Serial" Name="EquipmentSerial">
                    <Input @bind-Value="EquipmentDto.EquipmentSerial"
                           Placeholder="e.g., FNC-2023-001" />
                </FormItem>
            </Col>
        </Row>
        <!-- Description + Note -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="Equipment Description" Name="EquipmentDescription">
                <Input @bind-Value="EquipmentDto.EquipmentDescription"
                       Placeholder="e.g., FANUC α-D21MiB5" />
            </FormItem>
            </Col>

            <Col Span="12">
            <FormItem Label="Equipment Note" Name="EquipmentNote">
                <Input @bind-Value="EquipmentDto.EquipmentNote"
                       Placeholder="e.g., FNC-2023-001" />
            </FormItem>
            </Col>
        </Row>
        <!-- LocName + Purchase Date -->
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Purchase Date" Name="BuyDate">
                    <DatePicker @bind-Value="EquipmentDto.BuyDate"
                                Style="width:100%" />
                </FormItem>
            </Col>

            <Col Span="12">
                <FormItem Label="Purchase Price" Name="BuyPrice">
                    <AntDesign.InputNumber TValue="decimal?"
                       @bind-Value="EquipmentDto.BuyPrice" />
                </FormItem>
            </Col>
            <Col Span="4">
            <FormItem Label="Active" Name="IsActive">
                <Switch @bind-Checked="EquipmentDto.IsActive" />
            </FormItem>
            </Col>
        </Row>
        <!-- LocName + Department + Factory -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="LocName" Name="LocCode">
                <Input @bind-Value="EquipmentDto.LocCode"
                           Placeholder="e.g., Workshop A - Bay 01" />
                </FormItem>
            </Col>
            <Col Span="12">
            <FormItem Label="Department" Name="DeptID">

                <Select TValue="int?"
                        @bind-Value="EquipmentDto.DeptID"
                        DataSource="Departments"
                        ValueName="DeptID"
                        LabelName="DeptFullName"
                        Placeholder="Select department"
                        ShowSearch
                        AllowClear>
                </Select>

            </FormItem>


            </Col>
        </Row>
        <!-- StsUseName + Sts Maintenance -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="StsUseName" Name="StsUseID">
                    <Select TValue="int?"
                            @bind-Value="EquipmentDto.StsUseID"
                            DataSource="StatusUsing"
                            ValueName="StsUseID"
                            LabelName="StsUseName"
                            Placeholder="Select Status"
                            ShowSearch
                            AllowClear>
                    </Select>
                </FormItem>
            </Col>
            <Col Span="12">
            <FormItem Label="Maintenance Circle Time" Name="MaintenanceCircleTime">
                <Input @bind-Value="EquipmentDto.MaintenanceCircleTime"
                            Style="width:100%" />
            </FormItem>
            </Col>
        </Row>
        <!-- Vendor + ContactNo -->
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Vendor" Name="VendorID">
                    <Select TValue="int?"
                        @bind-Value="EquipmentDto.VendorID"
                        DataSource="Vendors"
                        ValueName="VendorID"
                        LabelName="VendorName"
                        Placeholder="Select vendor"
                        ShowSearch
                        AllowClear>
                    </Select>
                </FormItem>
            </Col>

            <Col Span="12">
                <FormItem Label="Contact No" Name="ContactNo">
                    <Input @bind-Value="EquipmentDto.ContactNo" />
                </FormItem>
            </Col>
        </Row>

        <!-- SAPCode + PIC -->
        <Row Gutter="16">
            <Col Span="12">
            <FormItem Label="SAP Code" Name="SAPCode">
                <Input @bind-Value="EquipmentDto.SAPCode"
                       Placeholder="e.g., FANUC α-D21MiB5" />
            </FormItem>
            </Col>

            <Col Span="12">
            <FormItem Label="PIC" Name="PICID">
                <Select TValue="int?"
                        @bind-Value="EquipmentDto.PICID"
                        DataSource="Users"
                        ValueName="WorkDayId"
                        LabelName="FullName"
                        Placeholder="Select PIC"
                        ShowSearch
                        EnableSearch
                        AllowClear>
                </Select>
            </FormItem>
            </Col>
            
        </Row>
    </Form>
</Modal>